# Maverick v3.0 Environment Variables
# Copy this file to .env and fill in your values

# NVIDIA NIM API Key (get from https://build.nvidia.com/)
NVIDIA_API_KEY=

# Groq API Key (optional, for fallback)
GROQ_API_KEY=

# LM Studio (no API key needed, runs locally)
# Just ensure LM Studio is running at http://127.0.0.1:1234

# Optional: Custom endpoints
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1